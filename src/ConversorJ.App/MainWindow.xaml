<Window x:Class="ConversorJ.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ConversorJ"
        Height="640"
        Width="920"
        MinHeight="560"
        MinWidth="760"
        Icon="Assets/conversorj.ico"
        Background="#F4F5F7">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="ConversorJ" FontSize="30" FontWeight="SemiBold" Foreground="#16181D" />
            <TextBlock Text="YouTube e X para MP3, MP4 ou TXT, salvo direto no seu computador."
                       Margin="0,6,0,24"
                       Foreground="#666D7A"
                       FontSize="14" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#DADDE5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,26,0">
                    <TextBlock Text="01  Plataforma" FontWeight="SemiBold" Foreground="#30343B" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,24">
                        <RadioButton Content="YouTube" IsChecked="{Binding IsYouTube}" IsEnabled="{Binding CanEdit}" />
                        <RadioButton Content="x.com (Twitter)" IsChecked="{Binding IsX}" IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <TextBlock Text="02  Link do video" FontWeight="SemiBold" Foreground="#30343B" />
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEdit}"
                             Margin="0,10,0,24" />

                    <TextBlock Text="03  Formato de saida" FontWeight="SemiBold" Foreground="#30343B" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,24">
                        <RadioButton Content="MP3 - Apenas audio" IsChecked="{Binding IsMp3}" IsEnabled="{Binding CanEdit}" />
                        <RadioButton Content="MP4 - Video completo" IsChecked="{Binding IsMp4}" IsEnabled="{Binding CanEdit}" />
                        <RadioButton Content="TXT - Transcricao" IsChecked="{Binding IsTxt}" IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding VideoResolutionVisibility}">
                        <TextBlock Text="Resolucao do video" FontWeight="SemiBold" Foreground="#30343B" />
                        <ComboBox ItemsSource="{Binding VideoResolutionChoices}"
                                  SelectedValue="{Binding SelectedVideoResolution}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,10,0,24" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding TranscriptionModelVisibility}">
                        <TextBlock Text="Modelo de transcricao" FontWeight="SemiBold" Foreground="#30343B" />
                        <ComboBox ItemsSource="{Binding TranscriptionModelChoices}"
                                  SelectedValue="{Binding SelectedTranscriptionModel}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,10,0,24" />
                    </StackPanel>

                    <TextBlock Text="Pasta de saida" FontWeight="SemiBold" Foreground="#30343B" />
                    <Grid Margin="0,10,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDirectory, Mode=OneWay}"
                                 IsEnabled="False" />
                        <Button Grid.Column="1"
                                Content="Escolher pasta"
                                Command="{Binding ChooseOutputDirectoryCommand}"
                                Margin="12,0,0,0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding ConvertButtonText}"
                                Command="{Binding ConvertCommand}"
                                Background="#16181D"
                                Foreground="White"
                                BorderBrush="#16181D" />
                        <Button Content="Nova conversao"
                                Command="{Binding NewConversionCommand}"
                                Margin="12,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FAFAFB"
                        BorderBrush="#EAECF1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#16181D"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,10,0,18"
                                   Foreground="#626A78"
                                   FontSize="14"
                                   TextWrapping="Wrap" />

                        <ProgressBar IsIndeterminate="True"
                                     Height="7"
                                     Visibility="{Binding ProgressVisibility}"
                                     Margin="0,0,0,20" />

                        <Border Background="White"
                                BorderBrush="#E1E4EA"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Arquivo" FontWeight="SemiBold" Foreground="#30343B" />
                                <TextBlock Text="{Binding OutputFilename}"
                                           Margin="0,6,0,0"
                                           Foreground="#626A78"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Button Content="Abrir arquivo"
                                Command="{Binding OpenFileCommand}"
                                Margin="0,0,0,10" />
                        <Button Content="Abrir pasta"
                                Command="{Binding OpenFolderCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
